{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/projet/:slug", "destination": "/api/public-project?ogpage=:slug" },
    { "source": "/projets/:slug", "destination": "/api/public-project?ogpage=:slug" },
    { "source": "/realisation/:slug", "destination": "/api/showroom?ogpage=:slug" }
  ],
  "functions": {
    "api/generate-pdf.js": { "maxDuration": 60 },
    "api/offers.js":       { "maxDuration": 60 },
    "api/send-fiche.js":   { "maxDuration": 60 },
    "api/submit.js":       { "maxDuration": 30 },
    "api/buyer-info.js":   { "maxDuration": 15 },
    "api/docusign-webhook.js": { "maxDuration": 15 },
    "api/cron/fiche-queue.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/stale-hot-leads", "schedule": "0 7 * * *" },
    { "path": "/api/cron/fiche-queue", "schedule": "0 * * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://join.atombuyerclub.fr" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,DELETE,PATCH,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
